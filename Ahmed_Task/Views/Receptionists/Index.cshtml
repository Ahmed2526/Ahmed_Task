@model IEnumerable<ReceptionistVM>

@{
    ViewData["Title"] = "Receptionists";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/jquery.dataTables.min.css" />
}

<div class="container">

    <h1>Receptionists</h1>
    <hr />

    <table class="table table-hover">
        <thead>
            <tr>
                <th>User Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Is Locked Out</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var receptionist in Model)
            {
                <tr>
                    <td>@receptionist.UserName</td>
                    <td>@receptionist.Email</td>
                    <td>@receptionist.PhoneNumber</td>
                    <td>
                        @if (receptionist.IsLockedOut)
                        {
                            <span class="badge text-bg-danger">Locked</span>
                        }
                        else
                        {
                            <span class="badge text-bg-success">Active</span>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Assign" asp-route-id="@receptionist.Id" class="btn btn-primary me-2">Assign</a>
                        <a asp-action="Details" asp-route-id="@receptionist.Id" class="btn btn-primary">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {

    @* Jquery *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    @* Data tables *@
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>

    <script>
        $(document).ready(function () {

        $('.table').DataTable();

        });
    </script>
}