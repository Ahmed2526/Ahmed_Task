@model IEnumerable<UserVM>

@{
    ViewData["Title"] = "Users";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/jquery.dataTables.min.css" />
}

<div class="container">

    <div class="d-flex justify-content-between align-items-center">
        <h1>Users</h1>
    </div>
    <hr />

    <table class="table table-hover">
        <thead>
            <tr>
                <th>User Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Roles</th>
                <th>Is Locked Out</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.UserName</td>
                    <td>@user.Email</td>
                    <td>@user.PhoneNumber</td>
                    <td>
                        @foreach (var role in user.Roles)
                        {
                            <span class="badge bg-primary">@role</span>
                        }
                    </td>
                    <td>
                        @if (user.IsLockedOut)
                        {
                            <span class="badge text-bg-danger">Locked</span>
                        }
                        else
                        {
                            <span class="badge text-bg-success">Active</span>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-primary me-3">Edit</a>
                        @if (user.IsLockedOut)
                        {
                            <a onclick="toggleLock('@user.Id')" class="btn btn-success">Unlock</a>
                        }
                        else
                        {
                            <a onclick="toggleLock('@user.Id')" class="btn btn-danger">Lock</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@Html.AntiForgeryToken()

@section Scripts {

    @* Jquery *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    @* Sweet Alerts *@
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @* Data tables *@
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>

    <script>
        $(document).ready(function () {

        $('.table').DataTable();

        });

        function toggleLock(userId) {

        Swal.fire({
        title: 'Are you sure?',
        text: "User status will be updated",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#dc3545',
        cancelButtonColor: '#6c757d',
        confirmButtonText: 'Yes, continue'
        })
        .then((result) => {

        if (result.isConfirmed) {

        $.ajax({

        url: '/Users/ToggleLock/' + userId,
        type: 'POST',

        headers: {
        RequestVerificationToken:
        $('input[name="__RequestVerificationToken"]').val()
        },

        success: function (response) {

        Swal.fire({
        title: 'Success!',
        text: response.message,
        icon: 'success'
        })
        .then(() => {
        location.reload();
        });

        },

        error: function (response) {

        Swal.fire({
        title: 'Error!',
        text: response.message || 'Something went wrong',
        icon: 'error',
        confirmButtonText: 'Done'
        });

        }});}});}
    
        

       
    </script>
}