@model IEnumerable<DoctorVM>

@{
    ViewData["Title"] = "Doctors";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/jquery.dataTables.min.css" />
}

<h1>Doctors</h1>
<hr />

<table class="table table-hover">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Speciality</th>
            <th class="">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var doctor in Model)
        {
            <tr>
                <td>@doctor.Name</td>
                <td>@doctor.Email</td>
                <td>@doctor.Phone</td>
                <td>@doctor.Speciality</td>
                <td>
                    <a asp-action="Details" asp-route-id="@doctor.Id" class="btn btn-primary me-3">Details</a>
                    <a asp-action="Lock" asp-route-id="@doctor.Id" class="btn btn-danger">Lock</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>

    <script>
        $(document).ready(function () {

        $('.table').DataTable();

        });


    </script>
}